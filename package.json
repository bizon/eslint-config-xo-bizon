{
  "name": "eslint-config-xo-bizon",
  "version": "4.4.0",
  "description": "ESLint shareable config to be used with xo",
  "repository": "https://github.com/bizon/eslint-config-xo-bizon",
  "author": "Bertrand Marron <bertrand.marron@gmail.com>",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "check:ts": "tsc --noEmit",
    "build": "tsdown",
    "dev": "tsdown --watch"
  },
  "peerDependencies": {
    "xo": ">=3"
  },
  "devDependencies": {
    "@bizon/semantic-release-config": "^3.1.0",
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^24.12.3",
    "semantic-release": "^25.0.7",
    "tsdown": "^0.22.3",
    "typescript": "^7.0.2",
    "xo": "^4.0.0"
  },
  "keywords": [
    "eslintconfig",
    "xo",
    "xoxo",
    "code",
    "quality",
    "style",
    "lint",
    "linter",
    "jscs",
    "jshint",
    "jslint",
    "eslint",
    "validate",
    "code style",
    "standard",
    "strict",
    "check",
    "checker",
    "verify",
    "enforce",
    "hint",
    "bizon"
  ],
  "release": {
    "extends": "@bizon/semantic-release-config"
  },
  "packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b"
